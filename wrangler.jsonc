{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spoffline",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "main": "server.mjs",
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
